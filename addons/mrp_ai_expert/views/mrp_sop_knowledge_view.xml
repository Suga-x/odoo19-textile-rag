<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mrp_sop_knowledge_list" model="ir.ui.view">
        <field name="name">mrp.sop.knowledge.list</field>
        <field name="model">mrp.sop.knowledge</field>
        <field name="arch" type="xml">
            <list string="SOP Knowledge Base">
                <field name="sop_code"/>
                <field name="name"/>
                <field name="division"/>
                <field name="state" widget="badge" decoration-success="state == 'synced'"/>
            </list>
        </field>
    </record>

    <record id="view_mrp_sop_knowledge_form" model="ir.ui.view">
        <field name="name">mrp.sop.knowledge.form</field>
        <field name="model">mrp.sop.knowledge</field>
        <field name="arch" type="xml">
            <form string="SOP Knowledge Base">
                <header>
                    <button name="action_sync_to_ai" string="Sinkronisasi ke AI" type="object" class="btn-primary" invisible="state == 'synced'"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="sop_code"/>
                            <field name="name"/>
                        </group>
                        <group>
                            <field name="division"/>
                            <field name="sop_file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mrp_sop_knowledge" model="ir.actions.act_window">
        <field name="name">SOP Knowledge</field>
        <field name="res_model">mrp.sop.knowledge</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new record here
            </p>
        </field>
    </record>

    <menuitem id="menu_mrp_sop_knowledge" 
              name="AI Knowledge Base" 
              parent="mrp.menu_mrp_root" 
              action="action_mrp_sop_knowledge" 
              sequence="30"/>
</odoo>